# Gemini API Configuration
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY_1=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here

# Optional: Whisper API Configuration (for audio transcription)
# Get your API key from: https://platform.openai.com/api-keys
# Enables Whisper transcription feature ($0.006/min)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Feedback - GitHub Issue creation
# Create a PAT at: https://github.com/settings/tokens (repo scope required)
GITHUB_TOKEN=your_github_pat_here

# Optional: Feedback - Email notification (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
FEEDBACK_EMAIL=yiwao@arma-as.co.jp
